generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String     @id @default(uuid())
    email     String
    password  String
    name      String
    createdAt DateTime   @default(now())
    student   Student?
    roles     UserRole[]
    schoolId  String
    school    School     @relation(fields: [schoolId], references: [id])

    @@unique([schoolId, email]) // if a parent is working in 2 school then it will be helpful following tenant architecture 
}

model Role {
    id    String     @id @default(uuid())
    name  String     @unique
    users UserRole[]
}

model UserRole {
    userId String
    roleId String
    role   Role   @relation(fields: [roleId], references: [id])
    user   User   @relation(fields: [userId], references: [id])

    @@id([userId, roleId])
}

model Student {
    id            String        @id @default(uuid())
    userId        String        @unique
    firstName     String
    lastName      String
    gender        Gender
    dateOfBirth   DateTime
    phone         String?       @unique
    bloodGroup    String?
    address       String?
    admissionDate DateTime      @default(now())
    status        StudentStatus @default(ACTIVE)
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    enrollments   Enrollment[]
    user          User          @relation(fields: [userId], references: [id])
}

model AcademicYear {
    id          String       @id @default(uuid())
    name        String       @unique
    startDate   DateTime
    endDate     DateTime
    createdAt   DateTime     @default(now())
    enrollments Enrollment[]
    school      School       @relation(fields: [schoolId], references: [id])
    schoolId    String
}

model Class {
    id          String    @id @default(uuid())
    name        String
    description String?
    createdAt   DateTime  @default(now())
    sections    Section[]
    school      School    @relation(fields: [schoolId], references: [id])
    schoolId    String

    @@unique([schoolId, name])
}

model Section {
    id          String       @id @default(uuid())
    name        String
    classId     String
    createdAt   DateTime     @default(now())
    enrollments Enrollment[]
    class       Class        @relation(fields: [classId], references: [id])
    school      School?      @relation(fields: [schoolId], references: [id])
    schoolId    String?
}

model Enrollment {
    id             String           @id @default(uuid())
    studentId      String
    academicYearId String
    sectionId      String
    rollNumber     Int
    status         EnrollmentStatus @default(ACTIVE)
    createdAt      DateTime         @default(now())
    academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
    section        Section          @relation(fields: [sectionId], references: [id])
    student        Student          @relation(fields: [studentId], references: [id])

    @@unique([academicYearId, sectionId, rollNumber])
    @@unique([studentId, academicYearId])
}

model School {
    id            String         @id @default(uuid())
    name          String
    slug          String         @unique
    logo          String?
    createdAt     DateTime       @default(now())
    users         User[]
    classes       Class[]
    sections      Section[]
    academicYears AcademicYear[]
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum StudentStatus {
    ACTIVE
    INACTIVE
    GRADUATED
    TRANSFERRED
}

enum EnrollmentStatus {
    ACTIVE
    COMPLETED
    DROPPED
}
